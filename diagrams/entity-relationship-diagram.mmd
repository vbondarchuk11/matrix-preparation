erDiagram
  USER {
    string id
    string name
    string email
    string role
    string avatar
  }

  CUSTOMER {
    string id
    string company
    string industry
    string owner
    string email
    string status
    string health
    string plan
    string region
    string segment
    number mrr
    number arr
    string renewalDate
  }

  DEAL {
    string id
    string name
    string customerId
    string customerName
    string owner
    string stage
    number value
    number probability
    string expectedClose
  }

  TASK {
    string id
    string title
    string account
    string assignee
    string dueDate
    string priority
    string status
    string type
  }

  NOTIFICATION {
    string id
    string title
    string description
    string timestamp
    string type
    boolean read
  }

  AUDIT_LOG {
    string id
    string actor
    string action
    string target
    string timestamp
    string ipAddress
    string severity
  }

  PROFILE {
    string id
    string name
    string email
    string title
    string phone
    string timezone
  }

  SETTINGS_STATE {
    string companyName
    string workspaceId
    boolean securityAlerts
    boolean weeklyDigest
    boolean autoAssignOwners
    string dealApprovalMode
    string theme
  }

  USER ||--o{ DEAL : owns
  USER ||--o{ TASK : assigned_to
  CUSTOMER ||--o{ DEAL : has
  CUSTOMER ||--o{ TASK : generates
  USER ||--o{ NOTIFICATION : receives
  USER ||--o{ AUDIT_LOG : produces
  USER ||--|| PROFILE : has
  PROFILE ||--|| SETTINGS_STATE : configures
